DEBUG=0
SECRET_KEY=change-me-very-long-random-secret
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
PUBLIC_BASE_URL=https://example.com

# Database (PostgreSQL)
POSTGRES_DB=jetistik
POSTGRES_USER=jetistik
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgres://jetistik:change-me-db-password@db:5432/jetistik

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Storage
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# HTTPS/security flags (set 1 behind TLS reverse proxy)
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Organizer requests
ORGANIZER_REQUEST_TO=yerzhan@blackboard.kz

# Email SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=Jetistik <noreply@example.com>
