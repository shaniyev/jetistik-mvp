# Database
DATABASE_URL=postgres://{{ postgres_user }}:{{ postgres_password }}@db:5432/{{ postgres_db }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}

# Redis
REDIS_URL={{ redis_url | default('redis://redis:6379/0') }}

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY={{ minio_root_user }}
MINIO_SECRET_KEY={{ minio_root_password }}
MINIO_BUCKET={{ minio_bucket | default('jetistik') }}
MINIO_USE_SSL=false
MINIO_ROOT_USER={{ minio_root_user }}
MINIO_ROOT_PASSWORD={{ minio_root_password }}

# Gotenberg
GOTENBERG_URL={{ gotenberg_url | default('http://gotenberg:3000') }}

# JWT
JWT_SECRET={{ jwt_secret }}
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# App
PUBLIC_BASE_URL={{ public_base_url | default('https://new.jetistik.kz') }}
APP_PORT=8080

# Email
SMTP_HOST={{ smtp_host | default('smtp.gmail.com') }}
SMTP_PORT={{ smtp_port | default('587') }}
SMTP_USER={{ smtp_user | default('') }}
SMTP_PASSWORD={{ smtp_password | default('') }}
SMTP_FROM={{ smtp_from | default('Jetistik <noreply@jetistik.kz>') }}
ORGANIZER_REQUEST_TO={{ organizer_email | default('yerzhan@blackboard.kz') }}
