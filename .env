DEBUG=1
SECRET_KEY=dev-secret-key-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
PUBLIC_BASE_URL=http://localhost:8000

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Если без redis, можно включить eager (тогда генерация будет синхронной)
CELERY_TASK_ALWAYS_EAGER=0

# Storage (MVP: local media)
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Organizer заявки
ORGANIZER_REQUEST_TO=yerzhan@blackboard.kz

# Email SMTP (example: Gmail SMTP)
# Заполните EMAIL_HOST_USER и EMAIL_HOST_PASSWORD (App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL=Jetistik <noreply@blackboard.kz>
