DEBUG=0
SECRET_KEY={{ secret_key }}
ALLOWED_HOSTS={{ domain }},www.{{ domain }},localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://{{ domain }},https://www.{{ domain }}
PUBLIC_BASE_URL=https://{{ domain }}

# Database (PostgreSQL)
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
DATABASE_URL=postgres://{{ postgres_user }}:{{ postgres_password }}@db:5432/{{ postgres_db }}

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=0

# Storage
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# HTTPS/security flags
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Organizer requests
ORGANIZER_REQUEST_TO={{ organizer_email | default('yerzhan@blackboard.kz') }}

# Email SMTP
EMAIL_HOST={{ email_host | default('smtp.gmail.com') }}
EMAIL_PORT={{ email_port | default('587') }}
EMAIL_HOST_USER={{ email_host_user | default('') }}
EMAIL_HOST_PASSWORD={{ email_host_password | default('') }}
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
DEFAULT_FROM_EMAIL={{ default_from_email | default('Jetistik <noreply@jetistik.kz>') }}
